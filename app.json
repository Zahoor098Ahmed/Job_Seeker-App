{
  "expo": {
    "name": "job-management",
    "slug": "job-management",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "https://cdn-1.webcatalog.io/catalog/jobseeker/jobseeker-icon-filled-256.png?v=1714777571203",
    "scheme": "jobmanagement",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "icon": "https://cdn-1.webcatalog.io/catalog/jobseeker/jobseeker-icon-filled-256.png?v=1714777571203"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "https://cdn-1.webcatalog.io/catalog/jobseeker/jobseeker-icon-filled-256.png?v=1714777571203",
        "backgroundColor": "#E6F4FE"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.sharyar701.jobmanagement"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "https://cdn-1.webcatalog.io/catalog/jobseeker/jobseeker-icon-filled-256.png?v=1714777571203",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "01eaaeec-d9e1-4900-9a67-ff79e1e37a67"
      }
    }
  }
}
